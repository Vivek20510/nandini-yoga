{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/generate-blog-draft.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
